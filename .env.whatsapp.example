# =============================================================================
# WhatsApp / Meta Cloud API
# =============================================================================
# Copiar estas variables al archivo .env del entorno correspondiente.
# No subir valores reales de tokens o secretos al repositorio.

WHATSAPP_PROVIDER=meta
WHATSAPP_WEBHOOK_ENABLED=True

# Debe coincidir con el token configurado en Meta Developers para validar el webhook.
WHATSAPP_VERIFY_TOKEN=cpc_whatsapp_verify_2026

# Credenciales de Meta. Mantener vacías en repositorio y configurarlas por entorno.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=

# Seguridad operativa para fases posteriores.
WHATSAPP_REQUIRE_CONFIRMATION=True
WHATSAPP_CONFIRMATION_EXP_MINUTES=15
WHATSAPP_DEFAULT_COUNTRY_CODE=52